<?xml version="1.0" encoding="utf-8"?>

<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- BACKGROUND -->

    <solid android:color="#FFFFFF"/>

    <!-- CORNER RADIUS -->

    <corners android:radius="14dp"/>

    <!-- BORDER -->

    <stroke
        android:width="1dp"
        android:color="#DDDDDD"/>

    <!-- PADDING -->

    <padding
        android:left="12dp"
        android:right="12dp"
        android:top="12dp"
        android:bottom="12dp"/>

</shape>